            "description": "Activates the approved merchant after a credential exists.",
            "body": {
              "mode": "raw",
              "raw": "{\"actor\":{\"actor_type\":\"OPS\",\"actor_id\":null,\"reason\":\"{{ops_reason}}\"}}"
