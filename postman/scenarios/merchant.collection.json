    },
    {
      "name": "MER-01 Active Merchant Can Use Payment And Refund Entry Points",
      "item": [
        {
          "name": "MER-01 Active Merchant Can Create Payment",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create payment returns 200', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "if (data.transaction_id) { pm.environment.set('payment_transaction_id', data.transaction_id); }",
                  "if (data.order_id) { pm.environment.set('order_id', data.order_id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Scenario PAY-01. Creates a merchant-authenticated payment request. Merchant HMAC headers are added automatically.",
            "body": {
              "mode": "raw",
              "raw": "{\"order_id\":\"{{order_id}}\",\"amount\":\"{{payment_amount}}\",\"description\":\"{{payment_description}}\",\"ttl_seconds\":{{payment_ttl_seconds}},\"metadata\":{\"customer_ref\":\"CUST-POSTMAN-1\"}}"
            },
            "url": "{{baseUrl}}/v1/payments"
          }
        },
        {
          "name": "Finalize Payment For Refund Entry Smoke",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Payment callback success returns 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Scenario CB-01. Simulates a successful provider payment callback for the current payment_transaction_id.",
            "body": {
              "mode": "raw",
              "raw": "{\"external_reference\":\"bank-{{payment_transaction_id}}\",\"transaction_reference\":\"{{payment_transaction_id}}\",\"status\":\"SUCCESS\",\"amount\":\"{{payment_amount}}\",\"paid_at\":\"{{now_iso}}\",\"source_type\":\"{{provider_source_type}}\",\"raw_payload\":{\"provider_status\":\"00\",\"trace_id\":\"trace-{{payment_transaction_id}}\"}}"
            },
            "url": "{{baseUrl}}/v1/provider/callbacks/payment"
          }
        },
        {
          "name": "MER-01 Active Merchant Can Create Refund",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create refund returns 200', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "if (data.refund_transaction_id) { pm.environment.set('refund_transaction_id', data.refund_transaction_id); }",
                  "if (data.refund_id) { pm.environment.set('refund_id', data.refund_id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Scenario REF-01. Creates a full refund for the successful payment_transaction_id.",
            "body": {
              "mode": "raw",
              "raw": "{\"original_transaction_id\":\"{{payment_transaction_id}}\",\"refund_id\":\"{{refund_id}}\",\"refund_amount\":\"{{refund_amount}}\",\"reason\":\"{{refund_reason}}\"}"
            },
            "url": "{{baseUrl}}/v1/refunds"
          }
        }
      ]
    }
  ]
