{
  "info": {
    "_postman_id": "4ce3eb80-28de-40e4-ba37-3df80bfc6fbd",
    "name": "Mini Payment Gateway - Merchant Scenarios",
    "description": "Companion for docs/testing/scenarios/merchant.md.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function suffix() {",
          "  return Math.random().toString(16).slice(2, 10);",
          "}",
          "",
          "function ensure(name, value) {",
          "  if (!pm.environment.get(name)) {",
          "    pm.environment.set(name, value);",
          "  }",
          "}",
          "",
          "ensure('baseUrl', 'http://127.0.0.1:8000');",
          "ensure('merchant_id', `m_pm_${suffix()}`);",
          "ensure('merchant_name', 'QA Demo Merchant');",
          "ensure('legal_name', 'QA Demo Merchant LLC');",
          "ensure('contact_name', 'QA Ops');",
          "ensure('contact_email', `qa_${suffix()}@example.com`);",
          "ensure('contact_phone', '+84000000000');",
          "ensure('webhook_url', 'https://example.com/webhooks/payment-gateway');",
          "ensure('settlement_account_name', 'QA Demo Merchant LLC');",
          "ensure('settlement_account_number', '123456789');",
          "ensure('settlement_bank_code', 'DEMO');",
          "ensure('access_key', `ak_pm_${suffix()}`);",
          "ensure('merchant_secret', `pm-secret-${suffix()}-${suffix()}`);",
          "ensure('rotated_access_key', `ak_rotated_${suffix()}`);",
          "ensure('rotated_merchant_secret', `pm-rotated-secret-${suffix()}-${suffix()}`);",
          "ensure('order_id', `ORDER-PM-${Date.now()}`);",
          "ensure('refund_id', `REF-PM-${Date.now()}`);",
          "ensure('reconciliation_order_id', `ORDER-REC-${Date.now()}`);",
          "ensure('payment_amount', '12345.00');",
          "ensure('payment_description', 'QA Postman payment');",
          "ensure('payment_ttl_seconds', '900');",
          "ensure('refund_amount', pm.environment.get('payment_amount') || '12345.00');",
          "ensure('refund_reason', 'QA Postman refund');",
          "ensure('reconciliation_mismatch_amount', '99999.00');",
          "ensure('provider_source_type', 'SIMULATOR');",
          "ensure('ops_reason', 'QA via Postman');",
          "ensure('lock_idempotency_key', 'false');",
          "",
          "pm.environment.set('now_iso', new Date().toISOString());",
          "",
          "if (pm.environment.get('lock_idempotency_key') !== 'true') {",
          "  pm.environment.set('idempotency_key', `idem-${Date.now()}-${suffix()}`);",
          "}",
          "",
          "const path = '/' + pm.variables.replaceIn(pm.request.url.getPath()).replace(/^\\/+/, '');",
          "const requiresMerchantAuth = path.startsWith('/v1/payments') || path.startsWith('/v1/refunds');",
          "",
          "if (requiresMerchantAuth) {",
          "  const method = pm.request.method.toUpperCase();",
          "  const timestamp = new Date().toISOString();",
          "  let rawBody = '';",
          "  if (pm.request.body && pm.request.body.mode === 'raw') {",
          "    rawBody = pm.variables.replaceIn(pm.request.body.raw || '');",
          "  }",
          "  const bodyHash = CryptoJS.SHA256(CryptoJS.enc.Utf8.parse(rawBody)).toString(CryptoJS.enc.Hex);",
          "  const signingString = `${timestamp}.${method}.${path}.${bodyHash}`;",
          "  const secret = pm.environment.get('merchant_secret') || '';",
          "  const signature = CryptoJS.HmacSHA256(signingString, secret).toString(CryptoJS.enc.Hex);",
          "",
          "  pm.environment.set('merchant_timestamp', timestamp);",
          "  pm.environment.set('merchant_body_sha256_hex', bodyHash);",
          "  pm.environment.set('merchant_signing_string', signingString);",
          "  pm.environment.set('merchant_signature', signature);",
          "",
          "  pm.request.headers.upsert({ key: 'X-Merchant-Id', value: pm.environment.get('merchant_id') || '' });",
          "  pm.request.headers.upsert({ key: 'X-Access-Key', value: pm.environment.get('access_key') || '' });",
          "  pm.request.headers.upsert({ key: 'X-Timestamp', value: timestamp });",
          "  pm.request.headers.upsert({ key: 'X-Signature', value: signature });",
          "  pm.request.headers.upsert({ key: 'X-Idempotency-Key', value: pm.environment.get('idempotency_key') || '' });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Health returns 200', function () { pm.response.to.have.status(200); });",
              "const data = pm.response.json();",
              "pm.test('Health body is ok', function () { pm.expect(data.status).to.eql('ok'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "description": "Basic service liveness check.",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "ONB-01 Ops Registers Merchant",
      "item": [
        {
          "name": "Create Merchant",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create merchant returns 200', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "if (data.merchant_id) { pm.environment.set('merchant_id', data.merchant_id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Scenario ONB-01. Creates a merchant in PENDING_REVIEW state.",
            "body": {
              "mode": "raw",
              "raw": "{\"actor\":{\"actor_type\":\"OPS\",\"actor_id\":null,\"reason\":\"{{ops_reason}}\"},\"merchant_id\":\"{{merchant_id}}\",\"merchant_name\":\"{{merchant_name}}\",\"legal_name\":\"{{legal_name}}\",\"contact_name\":\"{{contact_name}}\",\"contact_email\":\"{{contact_email}}\",\"contact_phone\":\"{{contact_phone}}\",\"webhook_url\":\"{{webhook_url}}\",\"settlement_account_name\":\"{{settlement_account_name}}\",\"settlement_account_number\":\"{{settlement_account_number}}\",\"settlement_bank_code\":\"{{settlement_bank_code}}\"}"
            },
            "url": "{{baseUrl}}/v1/ops/merchants"
          }
        }
      ]
    },
    {
      "name": "ONB-02 Ops Submits Onboarding Case",
      "item": [
        {
          "name": "Submit Onboarding Case",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Submit onboarding returns 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Scenario ONB-02. Creates or updates the merchant onboarding case.",
            "body": {
              "mode": "raw",
              "raw": "{\"actor\":{\"actor_type\":\"OPS\",\"actor_id\":null,\"reason\":\"{{ops_reason}}\"},\"domain_or_app_name\":\"QA Demo Shop\",\"submitted_profile_json\":{\"business_type\":\"online_shop\"},\"documents_json\":{\"business_license\":\"qa-license.pdf\"},\"review_checks_json\":{\"risk_level\":\"LOW\"}}"
            },
            "url": "{{baseUrl}}/v1/ops/merchants/{{merchant_id}}/onboarding-case"
          }
        }
      ]
    },
    {
      "name": "ONB-03 Ops Approves Onboarding Case",
      "item": [
        {
          "name": "Approve Onboarding Case",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Approve onboarding returns 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Scenario ONB-03. Approves the current onboarding case.",
            "body": {
              "mode": "raw",
              "raw": "{\"actor\":{\"actor_type\":\"OPS\",\"actor_id\":null,\"reason\":\"{{ops_reason}}\"},\"reviewed_by\":null,\"decision_note\":\"Approved via Postman QA flow.\"}"
            },
            "url": "{{baseUrl}}/v1/ops/merchants/{{merchant_id}}/onboarding-case/approve"
          }
        }
      ]
    },
    {
      "name": "MER-02 Non-Active Merchant Cannot Use Entry Points",
      "item": [
        {
          "name": "Create Credential While Merchant Is Still Pending",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create credential returns 200', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "if (data.access_key) { pm.environment.set('access_key', data.access_key); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Creates the first active merchant credential. The secret is taken from the environment variable merchant_secret.",
            "body": {
              "mode": "raw",
              "raw": "{\"actor\":{\"actor_type\":\"OPS\",\"actor_id\":null,\"reason\":\"{{ops_reason}}\"},\"access_key\":\"{{access_key}}\",\"secret_key\":\"{{merchant_secret}}\"}"
            },
            "url": "{{baseUrl}}/v1/ops/merchants/{{merchant_id}}/credentials"
          }
        },
        {
          "name": "MER-02 Pending Merchant Payment Blocked",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 403', function () { pm.response.to.have.status(403); });",
                  "const data = pm.response.json();",
                  "pm.test('Error code is MERCHANT_NOT_ACTIVE', function () { pm.expect(data.error_code).to.eql('MERCHANT_NOT_ACTIVE'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "MER-02. Merchant has a valid credential but is not ACTIVE.",
            "body": {
              "mode": "raw",
              "raw": "{\"order_id\":\"{{order_id}}\",\"amount\":\"{{payment_amount}}\",\"description\":\"{{payment_description}}\",\"ttl_seconds\":{{payment_ttl_seconds}},\"metadata\":{\"customer_ref\":\"CUST-POSTMAN-1\"}}"
            },
            "url": "{{baseUrl}}/v1/payments"
          }
        },
        {
          "name": "MER-02 Pending Merchant Refund Blocked",
          "request": {
            "method": "POST",
            "description": "MER-02. Readiness fails before refund lookup.",
            "url": "{{baseUrl}}/v1/refunds",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"original_transaction_id\": \"pay_placeholder\", \"refund_id\": \"{{refund_id}}\", \"refund_amount\": \"{{refund_amount}}\", \"reason\": \"Blocked while merchant is pending\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 403', function () { pm.response.to.have.status(403); });",
                  "const data = pm.response.json();",
                  "pm.test('Error code is MERCHANT_NOT_ACTIVE', function () { pm.expect(data.error_code).to.eql('MERCHANT_NOT_ACTIVE'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "ONB-04 Ops Activates Merchant",
      "item": [
        {
          "name": "Activate Merchant",
