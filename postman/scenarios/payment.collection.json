            "body": {
              "mode": "raw",
              "raw": "{\"external_reference\":\"bank-{{payment_transaction_id}}\",\"transaction_reference\":\"{{payment_transaction_id}}\",\"status\":\"SUCCESS\",\"amount\":\"{{payment_amount}}\",\"paid_at\":\"{{now_iso}}\",\"source_type\":\"{{provider_source_type}}\",\"raw_payload\":{\"provider_status\":\"00\",\"trace_id\":\"trace-{{payment_transaction_id}}\"}}"
            },
            "url": "{{baseUrl}}/v1/provider/callbacks/payment"
          }
        },
        {
          "name": "PAY-08 Retry Same Order After Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 409', function () { pm.response.to.have.status(409); });",
                  "const data = pm.response.json();",
                  "pm.test('Error code is PAYMENT_ALREADY_SUCCESS', function () { pm.expect(data.error_code).to.eql('PAYMENT_ALREADY_SUCCESS'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Scenario PAY-01. Creates a merchant-authenticated payment request. Merchant HMAC headers are added automatically.",
            "body": {
              "mode": "raw",
              "raw": "{\"order_id\":\"{{order_id}}\",\"amount\":\"{{payment_amount}}\",\"description\":\"{{payment_description}}\",\"ttl_seconds\":{{payment_ttl_seconds}},\"metadata\":{\"customer_ref\":\"CUST-POSTMAN-1\"}}"
            },
            "url": "{{baseUrl}}/v1/payments"
          }
