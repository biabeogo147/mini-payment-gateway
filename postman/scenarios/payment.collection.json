                  "if (!pm.environment.get('other_access_key')) { pm.environment.set('other_access_key', `ak_other_${Date.now()}`); }",
                  "if (!pm.environment.get('other_merchant_secret')) { pm.environment.set('other_merchant_secret', `other-secret-${Date.now()}`); }"
