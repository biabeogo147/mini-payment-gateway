          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('unknown_merchant_id', `m_unknown_${Date.now()}`);",
                  "const path = '/' + pm.variables.replaceIn(pm.request.url.getPath()).replace(/^\\/+/, '');",
                  "const method = pm.request.method.toUpperCase();",
                  "let rawBody = '';",
                  "if (pm.request.body && pm.request.body.mode === 'raw') { rawBody = pm.variables.replaceIn(pm.request.body.raw || ''); }",
                  "const bodyHash = CryptoJS.SHA256(CryptoJS.enc.Utf8.parse(rawBody)).toString(CryptoJS.enc.Hex);",
                  "const timestamp = new Date().toISOString();",
                  "const signingString = `${timestamp}.${method}.${path}.${bodyHash}`;",
                  "const signature = CryptoJS.HmacSHA256(signingString, pm.environment.get('merchant_secret') || '').toString(CryptoJS.enc.Hex);",
                  "pm.request.headers.upsert({ key: 'X-Merchant-Id', value: pm.environment.get('unknown_merchant_id') || '' });",
                  "pm.request.headers.upsert({ key: 'X-Access-Key', value: pm.environment.get('access_key') || '' });",
                  "pm.request.headers.upsert({ key: 'X-Timestamp', value: timestamp });",
                  "pm.request.headers.upsert({ key: 'X-Signature', value: signature });"
                ]
              }
            },
