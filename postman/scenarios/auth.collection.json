              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "AUTH-05 setup. Rotates the active credential and preserves the previous values.",
            "body": {
              "mode": "raw",
              "raw": "{\"actor\":{\"actor_type\":\"OPS\",\"actor_id\":null,\"reason\":\"{{ops_reason}}\"},\"access_key\":\"{{rotated_access_key}}\",\"secret_key\":\"{{rotated_merchant_secret}}\"}"
            },
            "url": "{{baseUrl}}/v1/ops/merchants/{{merchant_id}}/credentials/rotate"
          }
        },
        {
          "name": "AUTH-05 Rotated Credential Fails",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const path = '/' + pm.variables.replaceIn(pm.request.url.getPath()).replace(/^\\/+/, '');",
                  "const method = pm.request.method.toUpperCase();",
                  "let rawBody = '';",
                  "if (pm.request.body && pm.request.body.mode === 'raw') { rawBody = pm.variables.replaceIn(pm.request.body.raw || ''); }",
                  "const bodyHash = CryptoJS.SHA256(CryptoJS.enc.Utf8.parse(rawBody)).toString(CryptoJS.enc.Hex);",
                  "const timestamp = new Date().toISOString();",
                  "const signingString = `${timestamp}.${method}.${path}.${bodyHash}`;",
                  "const signature = CryptoJS.HmacSHA256(signingString, pm.environment.get('inactive_merchant_secret') || '').toString(CryptoJS.enc.Hex);",
                  "pm.request.headers.upsert({ key: 'X-Merchant-Id', value: pm.environment.get('merchant_id') || '' });",
                  "pm.request.headers.upsert({ key: 'X-Access-Key', value: pm.environment.get('inactive_access_key') || '' });",
                  "pm.request.headers.upsert({ key: 'X-Timestamp', value: timestamp });",
                  "pm.request.headers.upsert({ key: 'X-Signature', value: signature });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 4xx', function () { pm.expect(pm.response.code).to.be.within(400, 499); });",
                  "const data = pm.response.json();",
                  "pm.test('Error code is AUTH_INVALID_SIGNATURE', function () { pm.expect(data.error_code).to.eql('AUTH_INVALID_SIGNATURE'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "AUTH-05. Uses the rotated-out credential after rotation.",
            "body": {
              "mode": "raw",
              "raw": "{\"order_id\":\"{{order_id}}\",\"amount\":\"{{payment_amount}}\",\"description\":\"{{payment_description}}\",\"ttl_seconds\":{{payment_ttl_seconds}},\"metadata\":{\"customer_ref\":\"CUST-POSTMAN-1\"}}"
            },
            "url": "{{baseUrl}}/v1/payments"
          }
        }
      ]
    }
  ]
