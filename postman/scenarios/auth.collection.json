    {
      "name": "AUTH-01 Missing Auth Header Fails",
      "item": [
        {
          "name": "AUTH-01 Missing Signature Header",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.request.headers.remove('X-Signature');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 4xx', function () { pm.expect(pm.response.code).to.be.within(400, 499); });",
                  "const data = pm.response.json();",
                  "pm.test('Error code is AUTH_MISSING_HEADER', function () { pm.expect(data.error_code).to.eql('AUTH_MISSING_HEADER'); });"
                ]
              }
