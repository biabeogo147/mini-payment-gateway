    {
      "name": "50 Template Actions",
      "item": [
        {
          "name": "Reject Onboarding Case (Template)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Template for ONB rejection testing. Use on a merchant whose onboarding is still pending review.",
            "body": {
              "mode": "raw",
              "raw": "{\"actor\":{\"actor_type\":\"OPS\",\"actor_id\":null,\"reason\":\"{{ops_reason}}\"},\"reviewed_by\":null,\"decision_note\":\"Rejected via Postman template.\"}"
            },
            "url": "{{baseUrl}}/v1/ops/merchants/{{merchant_id}}/onboarding-case/reject"
          }
        },
        {
          "name": "Rotate Credential",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Rotate credential returns 200', function () { pm.response.to.have.status(200); });",
                  "pm.environment.set('access_key', pm.environment.get('rotated_access_key'));",
                  "pm.environment.set('merchant_secret', pm.environment.get('rotated_merchant_secret'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Template for OPS-03. Rotates the credential and then updates access_key and merchant_secret in the active environment.",
            "body": {
