POSTGRES_DB=mini_payment_gateway
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
APP_ENV=local
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/mini_payment_gateway
PROVIDER_CALLBACK_SECRETS=simulator=dev-insecure-provider-callback-secret-change-me
WORKER_ENABLED=true
WORKER_LOOP_INTERVAL_SECONDS=15
PAYMENT_EXPIRATION_BATCH_LIMIT=200
WEBHOOK_DELIVERY_BATCH_LIMIT=100
WORKER_PAYMENT_EXPIRATION_ENABLED=true
WORKER_WEBHOOK_DELIVERY_ENABLED=true
WORKER_LOG_LEVEL=INFO
WORKER_HEARTBEAT_PATH=/tmp/worker.heartbeat
GATEWAY_BASE_URL=http://127.0.0.1:8000
DEMO_MODE=true
DEMO_PROVIDER_ID=simulator
DEMO_PROVIDER_CALLBACK_SECRET=dev-insecure-provider-callback-secret-change-me
DEMO_WEBHOOK_MAX_AGE_SECONDS=300
DEMO_REQUEST_TIMEOUT_SECONDS=10
