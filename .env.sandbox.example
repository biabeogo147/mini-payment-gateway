# Copy this file to /opt/mini-payment-gateway/.env on the sandbox host.
# Keep DATABASE_URL pointed at the Docker service host `postgres`.
# Keep the bind addresses at `127.0.0.1` for host-only access.
# Change them to the sandbox LAN IP (for example `192.168.1.199`) when internal
# clients need to connect directly over the network.

APP_ENV=sandbox
INTERNAL_AUTH_SECRET=change-me-internal-auth-secret
INTERNAL_AUTH_COOKIE_NAME=mini_payment_gateway_internal_session
INTERNAL_AUTH_TTL_SECONDS=43200
INTERNAL_AUTH_COOKIE_SECURE=false
MERCHANT_AUTH_SECRET=change-me-merchant-auth-secret
MERCHANT_AUTH_COOKIE_NAME=mini_payment_gateway_merchant_session
MERCHANT_AUTH_TTL_SECONDS=43200
MERCHANT_AUTH_COOKIE_SECURE=false
PROVIDER_CALLBACK_SECRETS=simulator=change-me-provider-callback-secret

POSTGRES_DB=mini_payment_gateway
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg2://postgres:change-me@postgres:5432/mini_payment_gateway

POSTGRES_BIND_ADDR=127.0.0.1
POSTGRES_PORT=5432
BACKEND_BIND_ADDR=127.0.0.1
BACKEND_PORT=8000
OPS_DASHBOARD_BIND_ADDR=127.0.0.1
OPS_DASHBOARD_PORT=4173
MERCHANT_DASHBOARD_BIND_ADDR=127.0.0.1
MERCHANT_DASHBOARD_PORT=4174

WORKER_ENABLED=true
WORKER_LOOP_INTERVAL_SECONDS=15
PAYMENT_EXPIRATION_BATCH_LIMIT=200
WEBHOOK_DELIVERY_BATCH_LIMIT=100
WORKER_PAYMENT_EXPIRATION_ENABLED=true
WORKER_WEBHOOK_DELIVERY_ENABLED=true
WORKER_LOG_LEVEL=INFO
WORKER_HEARTBEAT_PATH=/tmp/worker.heartbeat
